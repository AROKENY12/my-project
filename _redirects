n  --gray-800: #1f2937;\r\n  --gray-900: #111827;\r\n  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);\r\n  --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\r\n  --shadow-lg: 0 10px 25px rgba(0, 0, 0, 0.15);\r\n  --radius: 8px;\r\n  --radius-lg: 12px;\r\n}\r\n\r\nbody {\r\n  font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\r\n  background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #4c1d95 100%);\r\n  min-height: 100vh;\r\n  color: var(--gray-800);\r\n}\r\n\r\n.app-wrapper {\r\n  min-height: 100vh;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n/* Header */\r\n.app-header {\r\n  background: rgba(255, 255, 255, 0.95);\r\n  backdrop-filter: blur(10px);\r\n  border-bottom: 1px solid var(--gray-200);\r\n  padding: 16px 32px;\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 100;\r\n}\r\n\r\n.header-content {\r\n  max-width: 1600px;\r\n  margin: 0 auto;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.logo-section {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 16px;\r\n}\r\n\r\n.logo-icon {\r\n  font-size: 48px;\r\n  color: var(--primary);\r\n}\r\n\r\n.logo-section h1 {\r\n  font-size: 1.75rem;\r\n  font-weight: 700;\r\n  color: var(--gray-900);\r\n  margin: 0;\r\n}\r\n\r\n.logo-section p {\r\n  font-size: 0.875rem;\r\n  color: var(--gray-500);\r\n  margin: 0;\r\n}\r\n\r\n.active-user-badge {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  padding: 8px 16px;\r\n  background: var(--primary);\r\n  color: white;\r\n  border-radius: 20px;\r\n  font-weight: 500;\r\n  font-size: 0.875rem;\r\n}\r\n\r\n/* Tab Navigation */\r\n.tab-navigation {\r\n  background: rgba(255, 255, 255, 0.9);\r\n  backdrop-filter: blur(10px);\r\n  padding: 0 32px;\r\n  display: flex;\r\n  gap: 4px;\r\n  border-bottom: 1px solid var(--gray-200);\r\n  max-width: 1600px;\r\n  margin: 0 auto;\r\n  width: 100%;\r\n}\r\n\r\n.tab-button {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  padding: 16px 24px;\r\n  border: none;\r\n  background: transparent;\r\n  color: var(--gray-600);\r\n  font-size: 0.9375rem;\r\n  font-weight: 500;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n  border-bottom: 3px solid transparent;\r\n  margin-bottom: -1px;\r\n}\r\n\r\n.tab-button:hover {\r\n  color: var(--primary);\r\n  background: var(--gray-50);\r\n}\r\n\r\n.tab-button.active {\r\n  color: var(--primary);\r\n  border-bottom-color: var(--primary);\r\n  background: white;\r\n}\r\n\r\n/* Main Content */\r\n.main-content {\r\n  flex: 1;\r\n  padding: 32px;\r\n  max-width: 1600px;\r\n  margin: 0 auto;\r\n  width: 100%;\r\n}\r\n\r\n.tab-content {\r\n  animation: fadeIn 0.3s ease;\r\n}\r\n\r\n@keyframes fadeIn {\r\n  from { opacity: 0; transform: translateY(10px); }\r\n  to { opacity: 1; transform: translateY(0); }\r\n}\r\n\r\n/* Split Layout */\r\n.split-layout {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 32px;\r\n}\r\n\r\n@media (max-width: 1024px) {\r\n  .split-layout {\r\n    grid-template-columns: 1fr;\r\n  }\r\n}\r\n\r\n/* Panel */\r\n.panel {\r\n  background: white;\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-lg);\r\n  overflow: hidden;\r\n}\r\n\r\n.panel-header {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 12px;\r\n  padding: 20px 24px;\r\n  background: linear-gradient(135deg, var(--gray-50) 0%, var(--gray-100) 100%);\r\n  border-bottom: 1px solid var(--gray-200);\r\n}\r\n\r\n.panel-header h2 {\r\n  font-size: 1.125rem;\r\n  font-weight: 600;\r\n  color: var(--gray-800);\r\n  flex: 1;\r\n  margin: 0;\r\n}\r\n\r\n.panel-header .badge {\r\n  background: var(--primary);\r\n  color: white;\r\n  padding: 4px 12px;\r\n  border-radius: 12px;\r\n  font-size: 0.75rem;\r\n  font-weight: 600;\r\n}\r\n\r\n.panel-body {\r\n  padding: 24px;\r\n}\r\n\r\n/* Form Styles */\r\n.form-group {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.form-group label {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  font-size: 0.875rem;\r\n  font-weight: 500;\r\n  color: var(--gray-700);\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.form-group label svg {\r\n  color: var(--gray-400);\r\n}\r\n\r\n.required {\r\n  color: var(--danger);\r\n}\r\n\r\n.form-group input,\r\n.form-group select,\r\n.form-group textarea {\r\n  width: 100%;\r\n  padding: 12px 16px;\r\n  border: 2px solid var(--gray-200);\r\n  border-radius: var(--radius);\r\n  font-size: 0.9375rem;\r\n  transition: all 0.2s;\r\n  background: white;\r\n}\r\n\r\n.form-group input:focus,\r\n.form-group select:focus,\r\n.form-group textarea:focus {\r\n  outline: none;\r\n  border-color: var(--primary);\r\n  box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);\r\n}\r\n\r\n.form-group input.error,\r\n.form-group select.error {\r\n  border-color: var(--danger);\r\n}\r\n\r\n.form-group input::placeholder {\r\n  color: var(--gray-400);\r\n}\r\n\r\n.form-group textarea {\r\n  resize: vertical;\r\n  min-height: 80px;\r\n}\r\n\r\n.form-row {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 16px;\r\n}\r\n\r\n.hint {\r\n  display: block;\r\n  font-size: 0.75rem;\r\n  color: var(--gray-400);\r\n  margin-top: 4px;\r\n}\r\n\r\n.error-text {\r\n  display: block;\r\n  font-size: 0.75rem;\r\n  color: var(--danger);\r\n  margin-top: 4px;\r\n}\r\n\r\n/* Buttons */\r\n.btn {\r\n  display: inline-flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 8px;\r\n  padding: 12px 24px;\r\n  border: none;\r\n  border-radius: var(--radius);\r\n  font-size: 0.9375rem;\r\n  font-weight: 600;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n}\r\n\r\n.btn:disabled {\r\n  opacity: 0.6;\r\n  cursor: not-allowed;\r\n}\r\n\r\n.btn-full {\r\n  width: 100%;\r\n}\r\n\r\n.btn-primary {\r\n  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);\r\n  color: white;\r\n}\r\n\r\n.btn-primary:hover:not(:disabled) {\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 12px rgba(79, 70, 229, 0.4);\r\n}\r\n\r\n.btn-success {\r\n  background: linear-gradient(135deg, var(--success) 0%, var(--success-dark) 100%);\r\n  color: white;\r\n}\r\n\r\n.btn-success:hover:not(:disabled) {\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);\r\n}\r\n\r\n.btn-warning {\r\n  background: linear-gradient(135deg, var(--warning) 0%, var(--warning-dark) 100%);\r\n  color: white;\r\n}\r\n\r\n.btn-warning:hover:not(:disabled) {\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 4px 12px rgba(245, 158, 11, 0.4);\r\n}\r\n\r\n.btn-small {\r\n  padding: 8px 16px;\r\n  font-size: 0.8125rem;\r\n}\r\n\r\n.btn-icon {\r\n  padding: 8px;\r\n  background: var(--gray-100);\r\n  border: none;\r\n  border-radius: var(--radius);\r\n  color: var(--gray-600);\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n}\r\n\r\n.btn-icon:hover {\r\n  background: var(--gray-200);\r\n  color: var(--gray-800);\r\n}\r\n\r\n.btn-icon.danger:hover {\r\n  background: #fee2e2;\r\n  color: var(--danger);\r\n}\r\n\r\n/* Messages */\r\n.message {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  padding: 12px 16px;\r\n  border-radius: var(--radius);\r\n  font-size: 0.875rem;\r\n  margin-top: 16px;\r\n}\r\n\r\n.message.success {\r\n  background: #d1fae5;\r\n  color: #065f46;\r\n}\r\n\r\n.message.error {\r\n  background: #fee2e2;\r\n  color: #991b1b;\r\n}\r\n\r\n/* Alert Banner */\r\n.alert-banner {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 16px;\r\n  padding: 20px 24px;\r\n  background: white;\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow);\r\n  color: var(--gray-700);\r\n}\r\n\r\n.alert-banner svg {\r\n  color: var(--warning);\r\n  flex-shrink: 0;\r\n}\r\n\r\n.alert-banner span {\r\n  flex: 1;\r\n}\r\n\r\n/* User List */\r\n.user-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n}\r\n\r\n.user-card {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 16px;\r\n  padding: 16px;\r\n  background: var(--gray-50);\r\n  border: 2px solid var(--gray-200);\r\n  border-radius: var(--radius);\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n}\r\n\r\n.user-card:hover {\r\n  border-color: var(--primary-light);\r\n  background: white;\r\n}\r\n\r\n.user-card.selected {\r\n  border-color: var(--primary);\r\n  background: linear-gradient(135deg, rgba(79, 70, 229, 0.05) 0%, rgba(79, 70, 229, 0.1) 100%);\r\n}\r\n\r\n.user-avatar {\r\n  width: 48px;\r\n  height: 48px;\r\n  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: white;\r\n}\r\n\r\n.user-info {\r\n  flex: 1;\r\n}\r\n\r\n.user-name {\r\n  font-weight: 600;\r\n  color: var(--gray-800);\r\n}\r\n\r\n.user-email {\r\n  font-size: 0.875rem;\r\n  color: var(--gray-500);\r\n}\r\n\r\n.user-program {\r\n  font-size: 0.75rem;\r\n  color: var(--primary);\r\n  margin-top: 4px;\r\n}\r\n\r\n.select-indicator {\r\n  color: var(--gray-400);\r\n  transition: transform 0.2s;\r\n}\r\n\r\n.user-card:hover .select-indicator,\r\n.user-card.selected .select-indicator {\r\n  color: var(--primary);\r\n  transform: translateX(4px);\r\n}\r\n\r\n/* Task List */\r\n.task-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n  max-height: 500px;\r\n  overflow-y: auto;\r\n}\r\n\r\n.task-card {\r\n  display: flex;\r\n  align-items: flex-start;\r\n  gap: 16px;\r\n  padding: 16px;\r\n  background: var(--gray-50);\r\n  border: 1px solid var(--gray-200);\r\n  border-radius: var(--radius);\r\n  transition: all 0.2s;\r\n}\r\n\r\n.task-card:hover {\r\n  background: white;\r\n  box-shadow: var(--shadow-sm);\r\n}\r\n\r\n.task-status {\r\n  flex-shrink: 0;\r\n}\r\n\r\n.status-icon {\r\n  width: 24px;\r\n  height: 24px;\r\n}\r\n\r\n.status-icon.completed {\r\n  color: var(--success);\r\n}\r\n\r\n.status-icon.in-progress {\r\n  color: var(--warning);\r\n}\r\n\r\n.status-icon.pending {\r\n  color: var(--gray-400);\r\n}\r\n\r\n.task-content {\r\n  flex: 1;\r\n  min-width: 0;\r\n}\r\n\r\n.task-title {\r\n  font-weight: 600;\r\n  color: var(--gray-800);\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.task-description {\r\n  font-size: 0.875rem;\r\n  color: var(--gray-500);\r\n  margin-bottom: 8px;\r\n  display: -webkit-box;\r\n  -webkit-line-clamp: 2;\r\n  -webkit-box-orient: vertical;\r\n  overflow: hidden;\r\n}\r\n\r\n.task-meta {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n  align-items: center;\r\n}\r\n\r\n.meta-item {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 4px;\r\n  font-size: 0.75rem;\r\n  color: var(--gray-500);\r\n}\r\n\r\n.priority-badge {\r\n  padding: 2px 8px;\r\n  border-radius: 4px;\r\n  font-size: 0.6875rem;\r\n  font-weight: 600;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.priority-badge.high {\r\n  background: #fee2e2;\r\n  color: #991b1b;\r\n}\r\n\r\n.priority-badge.medium {\r\n  background: #fef3c7;\r\n  color: #92400e;\r\n}\r\n\r\n.priority-badge.low {\r\n  background: #d1fae5;\r\n  color: #065f46;\r\n}\r\n\r\n.status-badge {\r\n  padding: 2px 8px;\r\n  border-radius: 4px;\r\n  font-size: 0.6875rem;\r\n  font-weight: 600;\r\n  text-transform: capitalize;\r\n}\r\n\r\n.status-badge.pending {\r\n  background: var(--gray-200);\r\n  color: var(--gray-600);\r\n}\r\n\r\n.status-badge.in_progress {\r\n  background: #dbeafe;\r\n  color: #1e40af;\r\n}\r\n\r\n.status-badge.completed,\r\n.status-badge.done {\r\n  background: #d1fae5;\r\n  color: #065f46;\r\n}\r\n\r\n.task-actions {\r\n  flex-shrink: 0;\r\n  display: flex;\r\n  gap: 4px;\r\n}\r\n\r\n.task-actions .btn-icon.success {\r\n  color: var(--success);\r\n}\r\n\r\n.task-actions .btn-icon.success:hover:not(:disabled) {\r\n  background: #d1fae5;\r\n}\r\n\r\n.task-actions .btn-icon:disabled {\r\n  opacity: 0.4;\r\n  cursor: not-allowed;\r\n}\r\n\r\n/* Task Edit Form */\r\n.task-card.editing {\r\n  padding: 0;\r\n  border: 2px solid var(--primary);\r\n}\r\n\r\n.task-edit-form {\r\n  width: 100%;\r\n}\r\n\r\n.edit-form-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 12px 16px;\r\n  background: var(--primary);\r\n  color: white;\r\n  border-radius: var(--radius) var(--radius) 0 0;\r\n}\r\n\r\n.edit-form-header h4 {\r\n  margin: 0;\r\n  font-size: 0.9rem;\r\n  font-weight: 600;\r\n}\r\n\r\n.edit-form-header .btn-icon {\r\n  color: white;\r\n  padding: 4px;\r\n}\r\n\r\n.edit-form-header .btn-icon:hover {\r\n  background: rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.edit-form-body {\r\n  padding: 16px;\r\n  background: var(--gray-50);\r\n}\r\n\r\n.edit-form-body .form-group {\r\n  margin-bottom: 12px;\r\n}\r\n\r\n.edit-form-body label {\r\n  display: block;\r\n  font-size: 0.75rem;\r\n  font-weight: 600;\r\n  color: var(--gray-600);\r\n  margin-bottom: 4px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.edit-form-body .input {\r\n  font-size: 0.875rem;\r\n  padding: 8px 12px;\r\n}\r\n\r\n.edit-form-body textarea.input {\r\n  min-height: 60px;\r\n  resize: vertical;\r\n}\r\n\r\n.form-row {\r\n  display: grid;\r\n  grid-template-columns: repeat(3, 1fr);\r\n  gap: 12px;\r\n}\r\n\r\n.edit-form-actions {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: 8px;\r\n  padding: 12px 16px;\r\n  background: white;\r\n  border-top: 1px solid var(--gray-200);\r\n  border-radius: 0 0 var(--radius) var(--radius);\r\n}\r\n\r\n.edit-form-actions .btn {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  padding: 8px 16px;\r\n  font-size: 0.875rem;\r\n}\r\n\r\n.task-status {\r\n  cursor: pointer;\r\n  transition: transform 0.2s;\r\n}\r\n\r\n.task-status:hover {\r\n  transform: scale(1.1);\r\n}\r\n\r\n/* Empty State */\r\n.empty-state {\r\n  text-align: center;\r\n  padding: 48px 24px;\r\n  color: var(--gray-500);\r\n}\r\n\r\n.empty-icon {\r\n  font-size: 64px;\r\n  color: var(--gray-300);\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.empty-state p {\r\n  font-size: 1rem;\r\n  font-weight: 500;\r\n  color: var(--gray-600);\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.empty-state span {\r\n  font-size: 0.875rem;\r\n}\r\n\r\n/* Centered Panel for Reminders */\r\n.centered-panel {\r\n  display: flex;\r\n  justify-content: center;\r\n}\r\n\r\n.reminder-panel {\r\n  max-width: 600px;\r\n  width: 100%;\r\n}\r\n\r\n.reminder-info {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n  padding: 24px;\r\n  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);\r\n  border-radius: var(--radius);\r\n  margin-bottom: 24px;\r\n}\r\n\r\n.reminder-icon {\r\n  font-size: 48px;\r\n  color: var(--warning-dark);\r\n}\r\n\r\n.reminder-info h3 {\r\n  font-size: 1.125rem;\r\n  font-weight: 600;\r\n  color: var(--gray-800);\r\n  margin: 0 0 4px 0;\r\n}\r\n\r\n.reminder-info p {\r\n  font-size: 0.875rem;\r\n  color: var(--gray-600);\r\n  margin: 0;\r\n}\r\n\r\n.recipient-info {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  padding: 12px 16px;\r\n  background: var(--gray-100);\r\n  border-radius: var(--radius);\r\n  font-size: 0.875rem;\r\n  color: var(--gray-600);\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.recipient-info strong {\r\n  color: var(--gray-800);\r\n}\r\n\r\n/* ========================================\r\n   Authentication & Account Styles\r\n   ======================================== */\r\n\r\n/* Full Height Main Content */\r\n.main-content.full-height {\r\n  min-height: calc(100vh - 160px);\r\n}\r\n\r\n/* Auth Container */\r\n.auth-container {\r\n  display: flex;\r\n  justify-content: center;\r\n  align-items: center;\r\n  min-height: calc(100vh - 300px);\r\n  padding: 40px 20px;\r\n}\r\n\r\n.account-content {\r\n  min-height: calc(100vh - 200px);\r\n}\r\n\r\n.auth-panel {\r\n  background: white;\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-lg);\r\n  width: 100%;\r\n  max-width: 480px;\r\n  overflow: hidden;\r\n}\r\n\r\n.auth-header {\r\n  text-align: center;\r\n  padding: 40px 32px 24px;\r\n  background: linear-gradient(135deg, var(--gray-50) 0%, var(--gray-100) 100%);\r\n  border-bottom: 1px solid var(--gray-200);\r\n}\r\n\r\n.auth-icon {\r\n  color: var(--primary);\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.auth-header h2 {\r\n  font-size: 1.5rem;\r\n  font-weight: 700;\r\n  color: var(--gray-900);\r\n  margin: 0 0 8px 0;\r\n}\r\n\r\n.auth-header p {\r\n  color: var(--gray-500);\r\n  margin: 0;\r\n  font-size: 0.9375rem;\r\n}\r\n\r\n.auth-body {\r\n  padding: 32px;\r\n}\r\n\r\n.auth-divider {\r\n  display: flex;\r\n  align-items: center;\r\n  margin: 24px 0;\r\n}\r\n\r\n.auth-divider::before,\r\n.auth-divider::after {\r\n  content: '';\r\n  flex: 1;\r\n  height: 1px;\r\n  background: var(--gray-200);\r\n}\r\n\r\n.auth-divider span {\r\n  padding: 0 16px;\r\n  color: var(--gray-400);\r\n  font-size: 0.875rem;\r\n}\r\n\r\n/* Button Variants */\r\n.btn-large {\r\n  padding: 16px 24px;\r\n  font-size: 1rem;\r\n}\r\n\r\n.btn-secondary {\r\n  background: var(--gray-100);\r\n  color: var(--gray-700);\r\n  border: 2px solid var(--gray-200);\r\n}\r\n\r\n.btn-secondary:hover:not(:disabled) {\r\n  background: var(--gray-200);\r\n  border-color: var(--gray-300);\r\n}\r\n\r\n.btn-text {\r\n  background: transparent;\r\n  color: var(--primary);\r\n  padding: 12px;\r\n}\r\n\r\n.btn-text:hover {\r\n  background: rgba(79, 70, 229, 0.05);\r\n}\r\n\r\n.btn-logout {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 6px;\r\n  padding: 8px 16px;\r\n  background: transparent;\r\n  border: 2px solid var(--danger);\r\n  color: var(--danger);\r\n  border-radius: var(--radius);\r\n  font-size: 0.875rem;\r\n  font-weight: 500;\r\n  cursor: pointer;\r\n  transition: all 0.2s;\r\n}\r\n\r\n.btn-logout:hover {\r\n  background: var(--danger);\r\n  color: white;\r\n}\r\n\r\n/* Active User Section */\r\n.active-user-section {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 16px;\r\n}\r\n\r\n/* Account Dashboard */\r\n.account-dashboard {\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 32px;\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.profile-section {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 24px;\r\n}\r\n\r\n.profile-card {\r\n  background: white;\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-lg);\r\n  padding: 40px;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 32px;\r\n}\r\n\r\n.profile-avatar {\r\n  width: 120px;\r\n  height: 120px;\r\n  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  color: white;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.profile-info h2 {\r\n  font-size: 1.75rem;\r\n  font-weight: 700;\r\n  color: var(--gray-900);\r\n  margin: 0 0 12px 0;\r\n}\r\n\r\n.profile-email,\r\n.profile-program {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 8px;\r\n  color: var(--gray-600);\r\n  font-size: 1rem;\r\n  margin: 8px 0;\r\n}\r\n\r\n.profile-email svg,\r\n.profile-program svg {\r\n  color: var(--gray-400);\r\n}\r\n\r\n/* Stats Grid */\r\n.stats-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(2, 1fr);\r\n  gap: 16px;\r\n}\r\n\r\n.stat-card {\r\n  background: white;\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow);\r\n  padding: 24px;\r\n  text-align: center;\r\n  transition: all 0.2s;\r\n}\r\n\r\n.stat-card:hover {\r\n  transform: translateY(-4px);\r\n  box-shadow: var(--shadow-lg);\r\n}\r\n\r\n.stat-card svg {\r\n  color: var(--primary);\r\n  margin-bottom: 12px;\r\n}\r\n\r\n.stat-number {\r\n  font-size: 2.5rem;\r\n  font-weight: 700;\r\n  color: var(--gray-900);\r\n  line-height: 1;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.stat-label {\r\n  color: var(--gray-500);\r\n  font-size: 0.875rem;\r\n  font-weight: 500;\r\n}\r\n\r\n/* Quick Actions */\r\n.quick-actions {\r\n  background: white;\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-lg);\r\n  padding: 32px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: center;\r\n  height: 100%;\r\n}\r\n\r\n.quick-actions h3 {\r\n  font-size: 1.25rem;\r\n  font-weight: 600;\r\n  color: var(--gray-800);\r\n  margin: 0 0 24px 0;\r\n}\r\n\r\n.action-buttons {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 16px;\r\n}\r\n\r\n.action-buttons .btn {\r\n  padding: 20px 24px;\r\n  font-size: 1rem;\r\n}\r\n\r\n/* Tasks Layout - Use More Space */\r\n.tasks-layout {\r\n  grid-template-columns: 450px 1fr;\r\n  gap: 32px;\r\n  align-items: start;\r\n}\r\n\r\n.tasks-layout .panel:last-child {\r\n  max-height: calc(100vh - 280px);\r\n  overflow-y: auto;\r\n}\r\n\r\n/* Tab Button Disabled */\r\n.tab-button.disabled {\r\n  opacity: 0.5;\r\n  cursor: not-allowed;\r\n}\r\n\r\n.tab-button.disabled:hover {\r\n  background: transparent;\r\n  color: var(--gray-600);\r\n}\r\n\r\n/* Responsive Updates */\r\n@media (max-width: 1024px) {\r\n  .account-dashboard {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .tasks-layout {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .profile-card {\r\n    flex-direction: column;\r\n    text-align: center;\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .stats-grid {\r\n    grid-template-columns: 1fr 1fr;\r\n  }\r\n\r\n  .auth-panel {\r\n    max-width: 100%;\r\n  }\r\n\r\n  .auth-header {\r\n    padding: 24px;\r\n  }\r\n\r\n  .auth-body {\r\n    padding: 24px;\r\n  }\r\n\r\n  .active-user-section {\r\n    flex-direction: column;\r\n    gap: 8px;\r\n  }\r\n}\r\n\r\n/* Footer */\r\n.app-footer {\r\n  background: rgba(0, 0, 0, 0.3);\r\n  padding: 20px 32px;\r\n  text-align: center;\r\n}\r\n\r\n.app-footer p {\r\n  color: rgba(255, 255, 255, 0.7);\r\n  font-size: 0.875rem;\r\n}\r\n\r\n/* Animations */\r\n.spin {\r\n  animation: spin 1s linear infinite;\r\n}\r\n\r\n@keyframes spin {\r\n  from { transform: rotate(0deg); }\r\n  to { transform: rotate(360deg); }\r\n}\r\n\r\n/* Scrollbar */\r\n::-webkit-scrollbar {\r\n  width: 8px;\r\n  height: 8px;\r\n}\r\n\r\n::-webkit-scrollbar-track {\r\n  background: var(--gray-100);\r\n  border-radius: 4px;\r\n}\r\n\r\n::-webkit-scrollbar-thumb {\r\n  background: var(--gray-300);\r\n  border-radius: 4px;\r\n}\r\n\r\n::-webkit-scrollbar-thumb:hover {\r\n  background: var(--gray-400);\r\n}\r\n\r\n/* Responsive */\r\n@media (max-width: 768px) {\r\n  .app-header {\r\n    padding: 12px 16px;\r\n  }\r\n\r\n  .header-content {\r\n    flex-direction: column;\r\n    gap: 12px;\r\n  }\r\n\r\n  .tab-navigation {\r\n    padding: 0 16px;\r\n    overflow-x: auto;\r\n  }\r\n\r\n  .tab-button {\r\n    padding: 12px 16px;\r\n    white-space: nowrap;\r\n  }\r\n\r\n  .main-content {\r\n    padding: 16px;\r\n  }\r\n\r\n  .form-row {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .reminder-info {\r\n    flex-direction: column;\r\n    text-align: center;\r\n  }\r\n}\r\n\r\n/* ========================================\r\n   Chat Interface Styles\r\n   ======================================== */\r\n\r\n.chat-layout {\r\n  display: grid;\r\n  grid-template-columns: 1fr 350px;\r\n  gap: 24px;\r\n  max-width: 1400px;\r\n  margin: 0 auto;\r\n  height: calc(100vh - 250px);\r\n}\r\n\r\n.chat-container {\r\n  background: white;\r\n  border-radius: var(--radius-lg);\r\n  box-shadow: var(--shadow-lg);\r\n  display: flex;\r\n  flex-direction: column;\r\n  overflow: hidden;\r\n}\r\n\r\n.chat-header {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 16px;\r\n  padding: 20px 24px;\r\n  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);\r\n  color: white;\r\n}\r\n\r\n.chat-header h2 {\r\n  font-size: 1.25rem;\r\n  font-weight: 600;\r\n  margin: 0;\r\n}\r\n\r\n.chat-header p {\r\n  font-size: 0.875rem;\r\n  opacity: 0.9;\r\n  margin: 0;\r\n}\r\n\r\n.chat-messages {\r\n  flex: 1;\r\n  overflow-y: auto;\r\n  padding: 24px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 16px;\r\n  background: var(--gray-50);\r\n}\r\n\r\n.chat-welcome {\r\n  text-align: center;\r\n  padding: 40px;\r\n  color: va